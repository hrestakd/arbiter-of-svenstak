# Copy to .env.local for local dev. In Vercel, set these as project env vars
# (and prefer `vercel env pull .env.local` once the project is linked).

# --- Postgres (Neon via Vercel Marketplace) ---
DATABASE_URL=postgres://USER:PASS@HOST.neon.tech/DBNAME?sslmode=require

# --- Upstash Redis (KV via Vercel Marketplace) ---
KV_REST_API_URL=https://YOUR-DB.upstash.io
KV_REST_API_TOKEN=

# --- Vercel Blob ---
BLOB_READ_WRITE_TOKEN=

# --- Pusher Channels (server) ---
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=eu

# --- Pusher Channels (client, exposed by Vite) ---
VITE_PUSHER_KEY=
VITE_PUSHER_CLUSTER=eu

# --- GitHub OAuth (admin auth) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:5173/api/auth/callback

# --- Cookie / session signing ---
# 32+ random bytes, base64. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# --- App ---
APP_PUBLIC_URL=http://localhost:5173
